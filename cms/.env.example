# ─── Database ────────────────────────────────────────────────────────────────
DB_USER=directus
DB_PASSWORD=directus
DB_DATABASE=directus
DIRECTUS_DB_CONNECTION_STRING="postgresql://directus:directus@database:5432/directus"
DIRECTUS_DB_SSL__REJECT_UNAUTHORIZED=false

# ─── Directus Core ───────────────────────────────────────────────────────────
DIRECTUS_PORT=8055
DIRECTUS_KEY=change-me-random-key
DIRECTUS_SECRET=change-me-random-secret
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-admin-password

# ─── Public URL ──────────────────────────────────────────────────────────────
PUBLIC_URL=http://localhost:8055

# ─── Cache ───────────────────────────────────────────────────────────────────
CACHE_ENABLED=true
CACHE_AUTO_PURGE=true

# ─── WebSockets ──────────────────────────────────────────────────────────────
WEBSOCKETS_ENABLED=true

# ─── CORS ────────────────────────────────────────────────────────────────────
CORS_ENABLED=true
CORS_ORIGIN=true

# ─── Cookies ─────────────────────────────────────────────────────────────────
REFRESH_TOKEN_COOKIE_SECURE=false
REFRESH_TOKEN_COOKIE_SAME_SITE=lax
REFRESH_TOKEN_COOKIE_DOMAIN=localhost
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAME_SITE=lax
SESSION_COOKIE_DOMAIN=localhost

# ─── Extensions ──────────────────────────────────────────────────────────────
EXTENSIONS_PATH=./extensions
EXTENSIONS_AUTO_RELOAD=true

# ─── Repo Sync ───────────────────────────────────────────────────────────────
REPO_SYNC_GITHUB_OWNER=zenithbuild
REPO_SYNC_GITHUB_REPO=framework
REPO_SYNC_GITHUB_REF=master
REPO_SYNC_GITHUB_TOKEN=
REPO_SYNC_GITHUB_API_BASE=https://api.github.com
REPO_SYNC_SHARED_TOKEN=change-me-repo-sync-token
DOCS_SYNC_CRON=17 * * * *
CHANGELOG_SYNC_CRON=23 * * * *

# ─── Content Security Policy ────────────────────────────────────────────────
# Directus expects a valid CSP directive value here, not the old array:self syntax.
# Add extra allowed frame hosts as a space-separated list, for example:
# "'self' https://www.youtube.com https://player.vimeo.com"
CONTENT_SECURITY_POLICY_DIRECTIVES__FRAME_SRC="'self'"

# ─── Email (optional) ───────────────────────────────────────────────────────
EMAIL_TRANSPORT=smtp
EMAIL_FROM=noreply@example.com
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=
EMAIL_SMTP_PASSWORD=

# ─── Cloudinary Storage (optional) ──────────────────────────────────────────
STORAGE_CLOUDINARY_DRIVER=
STORAGE_CLOUDINARY_CLOUD_NAME=
STORAGE_CLOUDINARY_API_KEY=
STORAGE_CLOUDINARY_API_SECRET=
