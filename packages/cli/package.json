{
  "name": "@zenithbuild/cli",
  "version": "0.6.6",
  "description": "Deterministic project orchestrator for Zenith framework",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "dist/**",
    "package.json"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/zenithbuild/framework",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/zenithbuild/framework/issues"
  },
  "homepage": "https://github.com/zenithbuild/framework#readme",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "mkdir -p dist && cp -a src/* dist/",
    "test": "node --experimental-vm-modules $(node -e \"const path=require('node:path');const pkg=require.resolve('jest/package.json');process.stdout.write(path.join(path.dirname(pkg),'bin/jest.js'))\") --config jest.config.js --forceExit --runInBand",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@zenithbuild/compiler": "0.6.6",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@jest/globals": "^30.2.0",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "typescript": "^5.7.3"
  },
  "private": false
}
