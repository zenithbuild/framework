{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "dist",
    "allowJs": true,
    "checkJs": true,
    "declaration": true,
    "declarationMap": false,
    "noFallthroughCasesInSwitch": true,
    "sourceMap": false,
    "emitDeclarationOnly": false,
    "noImplicitReturns": true,
    "noEmit": true,
    "esModuleInterop": true,
    "lib": ["ES2022"],
    "types": ["node"]
  },
  "include": [
    "src/toolchain-paths.ts",
    "src/toolchain-runner.ts",
    "src/compiler-bridge-runner.js",
    "src/version-check.ts",
    "src/types/index.js",
    "src/types/generate-env-dts.js",
    "src/types/generate-routes-dts.js",
    "src/ui/env.ts",
    "src/ui/format.ts",
    "src/ui/logger.ts"
  ],
  "exclude": [
    "dist",
    "tests",
    "node_modules"
  ]
}
