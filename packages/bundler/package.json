{
  "name": "@zenithbuild/bundler",
  "version": "0.6.8",
  "scripts": {
    "build": "rm -rf dist && cargo build --release && tsc -p tsconfig.meta.json && node ../../scripts/stage-bundler-platform-package.mjs",
    "contract:deps": "node dependency_contract.spec.js",
    "contract:scan": "node contract-scan.mjs",
    "contract:imports": "node --test tests/template_import_boundary.test.js",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@types/node": "latest",
    "@types/bun": "latest",
    "typescript": "^5"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "package.json",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/zenithbuild/framework",
    "directory": "packages/bundler"
  },
  "bugs": {
    "url": "https://github.com/zenithbuild/framework/issues"
  },
  "homepage": "https://github.com/zenithbuild/framework#readme",
  "dependencies": {
    "@zenithbuild/router": "0.6.8",
    "@zenithbuild/runtime": "0.6.8"
  },
  "optionalDependencies": {
    "@zenithbuild/bundler-darwin-arm64": "0.6.8",
    "@zenithbuild/bundler-darwin-x64": "0.6.8",
    "@zenithbuild/bundler-linux-x64": "0.6.8",
    "@zenithbuild/bundler-win32-x64": "0.6.8"
  },
  "type": "module",
  "private": false
}
