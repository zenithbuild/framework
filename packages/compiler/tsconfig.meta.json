{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "ESNext",
    "target": "ES2022",
    "moduleResolution": "Bundler",
    "outDir": "dist",
    "rootDir": "meta",
    "strict": true,
    "skipLibCheck": true,
    "declaration": false,
    "sourceMap": false,
    "types": [
      "node"
    ]
  },
  "include": [
    "meta/**/*.ts"
  ],
  "exclude": [
    "dist",
    "node_modules"
  ]
}
