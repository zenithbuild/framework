{
  "name": "@zenithbuild/runtime",
  "version": "0.6.10",
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": "./dist/index.js",
    "./template": "./dist/template.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "RUNTIME_CONTRACT.md",
    "HYDRATION_CONTRACT.md",
    "README.md",
    "dist/**",
    "LICENSE",
    "package.json"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/zenithbuild/framework",
    "directory": "packages/runtime"
  },
  "bugs": {
    "url": "https://github.com/zenithbuild/framework/issues"
  },
  "homepage": "https://github.com/zenithbuild/framework#readme",
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "npm run build && NODE_OPTIONS=--experimental-vm-modules jest --config jest.config.js",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@types/node": "latest",
    "@jest/globals": "^30.2.0",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "typescript": "^5.7.3"
  },
  "private": false
}
