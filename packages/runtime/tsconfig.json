{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "dist",
    "allowJs": true,
    "checkJs": true,
    "declaration": true,
    "declarationMap": false,
    "noFallthroughCasesInSwitch": true,
    "sourceMap": false,
    "emitDeclarationOnly": false,
    "noImplicitReturns": true,
    "noEmit": true,
    "esModuleInterop": true,
    "lib": ["ES2022", "DOM"],
    "types": ["node"]
  },
  "include": [
    "src/env.ts",
    "src/platform.ts",
    "src/ref.ts",
    "src/signal.ts",
    "src/state.ts",
    "src/zeneffect.ts",
    "src/effect.js"
  ],
  "exclude": [
    "dist",
    "tests",
    "node_modules"
  ]
}
