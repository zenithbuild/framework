{
  "name": "zenith-benchmarks",
  "private": true,
  "type": "module",
  "scripts": {
    "run:cold-build": "node ./scripts/run-cold-build.mjs",
    "run:dev-startup": "node ./scripts/run-dev-startup.mjs",
    "run:hydration": "node ./scripts/run-hydration.mjs",
    "run:rebuild": "node ./scripts/run-rebuild.mjs",
    "run:matrix": "node ./scripts/run-matrix.mjs",
    "run:determinism": "node ./scripts/run-determinism.mjs",
    "run:bundle-analysis": "node ./scripts/run-bundle-analysis.mjs",
    "run:reactive-update": "node ./scripts/run-reactive-update.mjs",
