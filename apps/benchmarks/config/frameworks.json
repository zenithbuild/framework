      "packageManager": "npm",
      "supportedTracks": ["determinism", "bundle-analysis", "cold-build", "dev-startup", "hydration-runtime", "rebuild"],
      "rebuildSettle": {
        "mode": "browser-probe"
      },
      "cleanPaths": [".output", ".nuxt"],
      "buildArtifacts": [".output"],
      "env": {
