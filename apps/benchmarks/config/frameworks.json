{
  "schemaVersion": 1,
  "frameworks": [
    {
      "id": "zenith",
      "label": "Zenith Workspace Head",
      "fixtureSubdir": "zenith",
      "packageManager": "npm",
      "supportedTracks": ["determinism", "bundle-analysis", "cold-build", "dev-startup", "hydration-runtime", "rebuild", "reactive-update"],
      "rebuildSettle": {
        "mode": "dev-state"
      },
      "cleanPaths": ["dist", ".zenith"],
      "buildArtifacts": ["dist"],
      "env": {
        "ZENITH_STARTUP_PROFILE": "1"
      },
      "commands": {
        "install": ["npm", "install", "--silent"],
        "build": ["npm", "run", "build", "--silent"],
        "preview": ["npm", "run", "preview", "--silent", "--", "--host", "127.0.0.1", "--port", "$PORT"],
        "dev": ["npm", "run", "dev", "--silent", "--", "--host", "127.0.0.1", "--port", "$PORT"]
      },
      "readyProbe": {
        "mode": "json-status",
        "path": "/__zenith_dev/state",
        "expectStatus": 200,
        "expectStateStatus": "ok"
      }
    },
    {
      "id": "astro",
      "label": "Astro",
      "fixtureSubdir": "astro",
      "packageManager": "npm",
      "supportedTracks": ["determinism", "bundle-analysis", "cold-build", "dev-startup", "hydration-runtime", "rebuild", "reactive-update"],
      "rebuildSettle": {
        "mode": "browser-probe"
      },
      "cleanPaths": ["dist", ".astro"],
      "buildArtifacts": ["dist"],
      "env": {
        "ASTRO_TELEMETRY_DISABLED": "1"
      },
      "commands": {
        "install": ["npm", "install", "--silent"],
        "build": ["npm", "run", "build", "--silent"],
        "preview": ["npm", "run", "preview", "--silent", "--", "--host", "127.0.0.1", "--port", "$PORT"],
        "dev": ["npm", "run", "dev", "--silent", "--", "--host", "127.0.0.1", "--port", "$PORT"]
      },
      "readyProbe": {
        "mode": "http-status",
        "path": "/",
        "expectStatus": 200,
        "expectStateStatus": "ok"
      }
    },
    {
