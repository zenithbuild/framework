{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Zenith Benchmark Result",
  "type": "object",
  "required": ["schemaVersion", "runner", "runId", "generatedAt", "results"],
  "properties": {
    "schemaVersion": { "type": "integer", "const": 1 },
    "runner": { "type": "string" },
    "runId": { "type": "string" },
    "benchmark_profile": { "type": "string" },
    "results_quality": { "type": "string" },
    "generatedAt": { "type": "string" },
    "environment": { "type": "object" },
    "publication_policy": { "type": "object" },
    "publication_assessment": { "type": "object" },
    "results": {
      "type": "array",
      "items": { "type": "object" }
    }
  }
}
