<script server lang="ts">
    export const data = {
        pageTitle: "Zenith Smoke App"
    };
</script>

<script lang="ts">
const navOpen = signal(false);
const navToggleRef = ref();
const navLabelRef = ref();
const navPanelRef = ref();
const motionCardRef = ref();
const statusRef = ref();

function renderState() {
    const expanded = navOpen.get();

    if (navToggleRef.current) {
        navToggleRef.current.setAttribute("aria-expanded", expanded ? "true" : "false");
    }

    if (navLabelRef.current) {
        navLabelRef.current.textContent = expanded ? "Close navigation" : "Open navigation";
    }

    if (statusRef.current) {
        statusRef.current.textContent = expanded ? "open" : "closed";
    }

    if (navPanelRef.current) {
        navPanelRef.current.setAttribute("data-state", expanded ? "open" : "closed");
        navPanelRef.current.className = expanded
            ? "mt-4 grid gap-3 rounded-2xl border border-emerald-400/40 bg-emerald-400/10 p-4 text-sm text-emerald-50 transition"
            : "pointer-events-none mt-4 grid gap-3 rounded-2xl border border-slate-700 bg-slate-900/50 p-4 text-sm text-slate-400 opacity-60 transition";
    }

    if (motionCardRef.current) {
        motionCardRef.current.style.transform = expanded ? "translateY(0px) scale(1)" : "translateY(16px) scale(0.98)";
        motionCardRef.current.style.opacity = expanded ? "1" : "0.55";
        motionCardRef.current.style.transition = "transform 220ms ease, opacity 220ms ease";
    }
}

function toggleNav() {
    navOpen.set(!navOpen.get());
    renderState();
}

zenMount(() => {
    renderState();
});

zeneffect([navOpen], () => {
    renderState();
});
</script>

<DefaultLayout>
    <section class="mx-auto grid max-w-5xl gap-6 lg:grid-cols-[1.2fr_0.8fr]">
        <div class="space-y-5 rounded-3xl border border-slate-700 bg-slate-900/70 p-8 shadow-2xl shadow-black/30">
            <p class="text-xs uppercase tracking-[0.28em] text-emerald-300">Monorepo Smoke Gate</p>
            <h1 data-smoke-title class="text-4xl font-bold tracking-tight text-slate-100">Zenith Smoke App</h1>
            <p class="max-w-2xl text-slate-300">
                This fixture validates local workspace wiring, internal Tailwind compilation, dev CSS serving,
                and one deterministic interactive state transition.
            </p>
            <button
                ref={navToggleRef}
                data-smoke-nav-toggle
                type="button"
                aria-expanded="false"
                class="inline-flex items-center gap-3 rounded-full border border-emerald-400/50 bg-emerald-400/15 px-5 py-3 font-semibold text-emerald-100 transition hover:bg-emerald-400/20"
                on:click={toggleNav}
            >
                <span ref={navLabelRef}>Open navigation</span>
                <span class="rounded-full bg-slate-950/60 px-2 py-1 text-xs uppercase tracking-[0.2em]">toggle</span>
            </button>
            <p class="text-sm text-slate-400">
                Navigation state:
                <span ref={statusRef} data-smoke-status class="font-semibold text-slate-100">closed</span>
            </p>

            <div
                ref={navPanelRef}
                data-smoke-nav-panel
                data-state="closed"
                class="pointer-events-none mt-4 grid gap-3 rounded-2xl border border-slate-700 bg-slate-900/50 p-4 text-sm text-slate-400 opacity-60 transition"
            >
                <a href="/" class="rounded-xl bg-slate-950/70 px-4 py-3 text-slate-100">Home</a>
                <a href="/about" class="rounded-xl bg-slate-950/70 px-4 py-3 text-slate-100">About</a>
                <p>The smoke gate expects this panel to move from closed to open deterministically.</p>
            </div>
        </div>

        <aside class="rounded-3xl border border-slate-700 bg-gradient-to-br from-slate-900 via-slate-900 to-slate-800 p-8">
            <div
                ref={motionCardRef}
                data-smoke-anim-card
                class="rounded-3xl border border-sky-400/30 bg-sky-400/10 p-6"
            >
                <p class="text-xs uppercase tracking-[0.22em] text-sky-200">Animated State</p>
                <h2 class="mt-3 text-2xl font-semibold text-white">Style mutation probe</h2>
                <p class="mt-3 text-sm leading-6 text-slate-300">
                    This block changes transform and opacity when the navigation toggle is pressed.
                </p>
            </div>
        </aside>
    </section>
</DefaultLayout>
