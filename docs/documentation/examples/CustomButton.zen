<script lang="ts">
interface Props {
  label: string;
  disabled?: boolean;
  onClick: () => void;
}

const incoming = props as Props;
</script>

<button
  class="rounded bg-zinc-900 px-4 py-2 text-white transition-colors hover:bg-zinc-700 disabled:cursor-not-allowed disabled:opacity-50"
  disabled={incoming.disabled === true}
  on:click={incoming.onClick}
>
  {incoming.label}
</button>
