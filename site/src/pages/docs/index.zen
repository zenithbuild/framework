<script server lang="ts">
import { siteContent } from "../../content/index";
import { createPageMetadata } from "../../content/site/metadata";
import { loadDocumentationLandingSource } from "../../server/documentationPageSource";
import { loadSearchIndex } from "../../server/searchIndexLoader";

export const load = async (ctx) => {
  const source = await loadDocumentationLandingSource();
  const firstArticle = source.sections[0]?.entries[0];
  if (!firstArticle) return ctx.deny(404);
  const searchIndex = await loadSearchIndex();
  return ctx.data({
    pageTitle: "Documentation",
    pageDescription: "Start with Zenith, learn the .zen component model, and follow the canonical routing, reactivity, DOM, and deployment contracts.",
    metadata: createPageMetadata("/docs"),
    firstArticlePath: firstArticle.path,
    sections: source.sections,
    searchIndex,
    site: { navigation: siteContent.navigation, footer: siteContent.footer },
  });
};
</script>

<script setup="ts">
import DefaultLayout from "@/layouts/DefaultLayout.zen";
import PageHeader from "@/components/layout/PageHeader.zen";
import DocsTopicCard from "@/components/docs/DocsTopicCard.zen";
import CodePanel from "@/components/CodePanel.zen";
import SearchTrigger from "@/components/search/SearchTrigger.zen";
import Callout from "@/components/Callout.zen";
import Links from "@/components/ui/Links.zen";
import MotionController from "@/components/motion/MotionController.zen";
