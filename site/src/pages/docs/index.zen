const docsRootRef = ref<HTMLElement>();
const docsStartRef = ref<HTMLElement>();
const docsFoundationsRef = ref<HTMLElement>();
const docsServerRef = ref<HTMLElement>();
const docsDeliveryRef = ref<HTMLElement>();

</script>

<DefaultLayout title={data.pageTitle} description={data.pageDescription} metadata={data.metadata} navigationContent={data.site.navigation} footerContent={data.site.footer} currentPath="/docs" searchIndex={data.searchIndex}>
  <div ref={docsRootRef} data-page-shell="docs" class="bg-background text-foreground">
    <PageHeader
      eyebrow="Zenith documentation"
      title="The public contract, close to the code."
      description="Learn the compiler-owned component model, explicit reactive primitives, server route boundaries, and the tooling that keeps authored intent traceable."
      asideLabel="Current train"
      asideText="These demo docs follow the repository’s canonical Zenith agent, DOM, routing, and Tailwind contracts for the 0.8 package line."
    />
    <div class="mx-auto max-w-7xl px-4 py-4 sm:px-6 lg:px-8"><SearchTrigger scope="docs" label="Search docs" variant="inline" /></div>

    <section ref={docsStartRef} data-motion-section="docs-start" id="getting-started" aria-labelledby="getting-started-title" class="border-b border-border bg-muted px-4 py-20 sm:px-6 lg:px-8 lg:py-28">
      <div class="mx-auto grid w-full max-w-7xl grid-cols-4 gap-x-6 gap-y-12 md:grid-cols-12 lg:gap-x-12">
        <div class="col-span-4 md:col-span-4">
          <p class="font-mono text-[10px] uppercase tracking-[0.2em] text-primary">Start here</p>
          <h2 id="getting-started-title" class="mt-5 font-heading text-5xl font-semibold leading-[0.9] text-foreground sm:text-6xl">From an empty directory to a working route.</h2>
          <p class="mt-6 max-w-xl text-base leading-8 text-muted-foreground md:text-lg">Create a project, open the generated page, and work directly in a `.zen` file. The scaffold keeps the first path narrow.</p>
          <div class="mt-8">
            <Links href={data.firstArticlePath} surface="button" variant="primary" size="lg">Open getting started</Links>
          </div>
        </div>

        <div class="col-span-4 md:col-span-7 md:col-start-6">
          <CodePanel filename="terminal" label="Create a project">
<span class="text-primary">$</span> npm create zenith@latest my-app
<span class="text-primary">$</span> cd my-app
<span class="text-primary">$</span> npm run dev
          </CodePanel>
          <div class="mt-6 grid gap-3 sm:grid-cols-3">
            <div class="rounded-lg border border-border bg-card p-4">
              <p class="font-mono text-[10px] uppercase tracking-[0.18em] text-muted-foreground">01</p>
              <p class="mt-3 text-sm font-medium text-foreground">Route file created</p>
