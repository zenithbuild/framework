  <div class="col-span-4 lg:col-start-8 lg:col-span-5 flex flex-col gap-6 pt-12 lg:pt-2">
    <p class="text-lg lg:text-2xl text-foreground font-light leading-relaxed">
      {benchmarkParagraphOne}
    </p>
    <p class="text-base lg:text-lg text-muted-foreground leading-relaxed">
      {benchmarkParagraphTwo}
    </p>
    <p class="text-base lg:text-lg text-muted-foreground leading-relaxed">
      {benchmarkParagraphThree}
    </p>
  </div>

  <div class="col-span-4 lg:col-span-7 grid grid-cols-1 md:grid-cols-2 gap-6 pt-16 lg:pt-24 mt-16 lg:mt-24">
    <article class="flex flex-col gap-4 p-6">
      <span class="text-sm font-mono uppercase tracking-[0.18em] text-muted-foreground">{measurementOne.label}</span>
      <p class="text-sm lg:text-base leading-relaxed text-foreground">{measurementOne.detail}</p>
    </article>
    <article class="flex flex-col gap-4 p-6">
      <span class="text-sm font-mono uppercase tracking-[0.18em] text-muted-foreground">{measurementTwo.label}</span>
      <p class="text-sm lg:text-base leading-relaxed text-foreground">{measurementTwo.detail}</p>
    </article>
    <article class="flex flex-col gap-4 p-6">
      <span class="text-sm font-mono uppercase tracking-[0.18em] text-muted-foreground">{measurementThree.label}</span>
      <p class="text-sm lg:text-base leading-relaxed text-foreground">{measurementThree.detail}</p>
    </article>
    <article class="flex flex-col gap-4 p-6">
      <span class="text-sm font-mono uppercase tracking-[0.18em] text-muted-foreground">{measurementFour.label}</span>
      <p class="text-sm lg:text-base leading-relaxed text-foreground">{measurementFour.detail}</p>
    </article>
    <article class="flex flex-col gap-4 p-6">
      <span class="text-sm font-mono uppercase tracking-[0.18em] text-muted-foreground">{measurementFive.label}</span>
      <p class="text-sm lg:text-base leading-relaxed text-foreground">{measurementFive.detail}</p>
    </article>
    <article class="flex flex-col gap-4 p-6">
      <span class="text-sm font-mono uppercase tracking-[0.18em] text-muted-foreground">{measurementSix.label}</span>
      <p class="text-sm lg:text-base leading-relaxed text-foreground">{measurementSix.detail}</p>
    </article>
    <article class="flex flex-col gap-4 p-6 md:col-span-2">
      <span class="text-sm font-mono uppercase tracking-[0.18em] text-muted-foreground">{measurementSeven.label}</span>
      <p class="text-sm lg:text-base leading-relaxed text-foreground max-w-3xl">{measurementSeven.detail}</p>
    </article>
  </div>

  <div class="col-span-4 lg:col-span-5 pt-16 lg:pt-24 mt-16 lg:mt-24 lg:pl-12">
    <div class="flex h-full flex-col justify-between gap-8 p-8 lg:p-10">
      <span class="text-sm font-mono uppercase tracking-[0.18em] text-muted-foreground">
