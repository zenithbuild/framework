<script lang="ts">
interface BenchmarkMeasurement {
  label?: string;
  detail?: string;
}

interface BenchmarkMethodology {
  label?: string;
  title?: string;
  text?: string;
}

export interface Props {
  content: {
    eyebrow?: string;
    title?: string;
    body?: string[];
    measurements?: BenchmarkMeasurement[];
    methodology?: BenchmarkMethodology;
  };
}

const benchmarkContent = (props as Props).content || {};
const benchmarkBody = Array.isArray(benchmarkContent.body) ? benchmarkContent.body : [];
const benchmarkMeasurements = Array.isArray(benchmarkContent.measurements) ? benchmarkContent.measurements : [];
const benchmarkMethodology = benchmarkContent.methodology || {};
const emptyMeasurement = { label: "", detail: "" };

const benchmarkParagraphOne = typeof benchmarkBody[0] === "string" ? benchmarkBody[0] : "";
const benchmarkParagraphTwo = typeof benchmarkBody[1] === "string" ? benchmarkBody[1] : "";
const benchmarkParagraphThree = typeof benchmarkBody[2] === "string" ? benchmarkBody[2] : "";

const measurementOne = benchmarkMeasurements[0] || emptyMeasurement;
const measurementTwo = benchmarkMeasurements[1] || emptyMeasurement;
const measurementThree = benchmarkMeasurements[2] || emptyMeasurement;
const measurementFour = benchmarkMeasurements[3] || emptyMeasurement;
const measurementFive = benchmarkMeasurements[4] || emptyMeasurement;
const measurementSix = benchmarkMeasurements[5] || emptyMeasurement;
const measurementSeven = benchmarkMeasurements[6] || emptyMeasurement;
</script>

