<script lang="ts">
import Button from "@/components/ui/Button.zen";

export interface Props {
  content: any;
}

const aboutContent = (props as Props).content || {};
const aboutSections = aboutContent.sections || {};
const aboutHero = aboutSections.hero || {};
const aboutHeroIntro = aboutHero.intro || {};
