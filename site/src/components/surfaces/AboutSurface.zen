const aboutHeroChips = Array.isArray(aboutHero.chips) ? aboutHero.chips : [];
const aboutHeroActions = Array.isArray(aboutHero.actions) 
  ? aboutHero.actions.filter((action) => Boolean(action) && typeof action.href === "string" && action.href.trim().length > 0)
  : [];

const aboutWhyItems = Array.isArray(aboutWhy.items) ? aboutWhy.items : [];
const aboutPillars = Array.isArray(aboutPhilosophy.pillars) ? aboutPhilosophy.pillars : [];
