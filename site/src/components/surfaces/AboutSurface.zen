const aboutDifferenceCards = Array.isArray(aboutModel.differenceCards) ? aboutModel.differenceCards : [];
const aboutArchitectureParts = Array.isArray(aboutArchitecture.parts) ? aboutArchitecture.parts : [];
const aboutToolingFeatures = Array.isArray(aboutArchitectureTooling.features) ? aboutArchitectureTooling.features : [];
const aboutToolingVerified = Array.isArray(aboutArchitectureTooling.verified) ? aboutArchitectureTooling.verified : [];
const aboutTracks = Array.isArray(aboutStatus.tracks) ? aboutStatus.tracks : [];
const aboutRoadmap = Array.isArray(aboutStatus.roadmap) ? aboutStatus.roadmap : [];
const aboutFinalActions = Array.isArray(aboutFinalCta.actions)
  ? aboutFinalCta.actions.filter((action) => Boolean(action) && typeof action.href === "string" && action.href.trim().length > 0)
  : [];
